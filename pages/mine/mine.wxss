/* 用户头部 */
.user-header {
  background: linear-gradient(135deg, #ff4d4f, #ff7875);
  padding: 40px 24px 30px;
  display: flex; flex-direction: column; align-items: center;
}
.avatar {
  width: 64px; height: 64px; border-radius: 50%;
  background: rgba(255,255,255,0.2); display: flex;
  align-items: center; justify-content: center;
  font-size: 32px; margin-bottom: 12px;
}
.nickname { color: #fff; font-size: 18px; font-weight: 600; }
.uid { color: rgba(255,255,255,0.7); font-size: 12px; margin-top: 4px; }

/* 订单栏 */
.order-bar {
  display: flex; justify-content: space-between; align-items: center;
  padding: 16px; background: #fff; margin-top: 10px;
}
.bar-title { font-size: 15px; font-weight: 600; }
.bar-all { font-size: 13px; color: #999; }

/* 订单图标 */
.order-icons {
  display: flex; background: #fff; padding: 8px 0 16px;
}
.order-item {
  flex:1; display:flex; flex-direction:column; align-items:center; gap:6px;
}
.order-icon { font-size: 24px; }
.order-label { font-size: 12px; color: #666; }

/* 功能列表 */
.menu-list {
  background: #fff; margin-top: 10px;
}
.menu-item {
  display: flex; align-items: center; padding: 14px 16px;
  border-bottom: 1px solid #f5f5f5;
}
.menu-icon { font-size: 20px; margin-right: 12px; }
.menu-title { flex:1; font-size: 14px; }
.menu-arrow { color: #ccc; font-size: 18px; }
